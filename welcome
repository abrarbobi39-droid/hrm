            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            transform: translate(-50%, -50%);
            box-shadow: inset 0 0 10px rgba(6, 182, 212, 0.2);
            transition: width 0.3s, height 0.3s, border-color 0.3s, background-color 0.3s;
        }

        /* ৩D ব্যাকগ্রাউন্ড ক্যানভাস */
        #fluid-viewport {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            pointer-events: none;
            z-index: 1;
        }

        /* হাইপার গ্লাস মরফিজম */
        .hyper-glass {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(25px) saturate(180%);
            -webkit-backdrop-filter: blur(25px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.5), inset 0 1px 2px rgba(255, 255, 255, 0.15);
            position: relative;
        }

        .showcase-card {
            transform-style: preserve-3d;
            box-shadow: -20px 30px 80px rgba(0, 0, 0, 0.8);
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }
        
        .glass-nav {
            background: rgba(3, 6, 17, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            z-index: 100;
        }

        .studio-view { perspective: 2000px; }
        .interactive-content { position: relative; z-index: 10; }

        .shine-btn {
            position: relative;
            overflow: hidden;
        }
        .shine-btn::before {
            content: ''; position: absolute;
            top: 0; left: -100%; width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transform: skewX(-20deg);
        }
        .shine-btn:hover::before { left: 200%; transition: left 0.6s ease-in-out; }

        .feature-card {
            transform-style: preserve-3d;
            perspective: 1000px;
            transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease, box-shadow 0.4s ease;
        }
        .feature-card:hover {
            border-color: rgba(6, 182, 212, 0.5);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6), 0 0 40px rgba(6, 182, 212, 0.2);
        }

        .glow-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(6, 182, 212, 0.5), rgba(14, 165, 233, 0.5), transparent);
            box-shadow: 0 0 15px rgba(6, 182, 212, 0.4);
        }

        /* ফিক্সড এনিমেটেড টেক্সট গ্রেডিয়েন্ট */
        .animated-text-grad {
            background: linear-gradient(90deg, #06B6D4, #0EA5E9, #6366F1, #06B6D4);
            background-size: 200% auto;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: textFlow 4s linear infinite;
            display: inline-block;
        }
        @keyframes textFlow {
            0% { background-position: 0% center; }
            100% { background-position: 200% center; }
        }

        .floating-node {
            animation: floatMotion 4s ease-in-out infinite alternate;
        }
        @keyframes floatMotion {
            0% { transform: translateY(0px) rotate(0deg); }
            100% { transform: translateY(-10px) rotate(5deg); }
        }
    </style>
