                    <span class="text-[10px] font-mono text-slate-400">All Systems Operational</span>
                    <span class="flex h-2 w-2 rounded-full bg-emerald-400 animate-ping"></span>
                </div>
            </div>
        </div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-slate-500 font-bold tracking-widest uppercase">
            <div>&copy; 2026 HRMPro. All rights reserved.</div>
            <div class="flex space-x-6 text-base mt-4 md:mt-0">
                <i class="fa-brands fa-twitter hover:text-cyan-400 hover:scale-110 transition-all cursor-pointer"></i>
                <i class="fa-brands fa-github hover:text-white hover:scale-110 transition-all cursor-pointer"></i>
                <i class="fa-brands fa-linkedin hover:text-blue-400 hover:scale-110 transition-all cursor-pointer"></i>
            </div>
        </div>
    </footer>

    <!-- স্ক্রিপ্ট অ্যানিমেশন লাইব্রেরি সমূহ -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js"></script>
    
    <script>
        gsap.registerPlugin(ScrollTrigger);

        // প্রিলোডার প্রসেস ট্র্যাকার
        window.addEventListener('DOMContentLoaded', () => {
            const bar = document.getElementById('loading-bar');
            bar.style.width = '100%';
            setTimeout(() => {
                gsap.to("#preloader", { opacity: 0, duration: 0.5, onComplete: () => document.getElementById("preloader").remove() });
                triggerHeroAnimations();
            }, 1500);
        });

        // 🌟 কাস্টম কার্সর ট্র্যাকিং মেকানিজম (আপডেটেড ও হাইপার-ভিজিবল) 🌟
        const dot = document.getElementById('custom-dot');
        const ring = document.getElementById('custom-ring');
        let mouseX = 0, mouseY = 0, ringX = 0, ringY = 0;

        window.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            
            // ডটটিকে একদম ইনস্ট্যান্টলি মাউসের পজিশনে রাখা হচ্ছে
            dot.style.left = mouseX + 'px';
            dot.style.top = mouseY + 'px';
        });

        function animateCursorRing() {
            // রিং ট্র্যাকিং আরও নিখুঁত ও স্মুথ করা হলো
            ringX += (mouseX - ringX) * 0.15;
            ringY += (mouseY - ringY) * 0.15;
            ring.style.left = ringX + 'px';
            ring.style.top = ringY + 'px';
            requestAnimationFrame(animateCursorRing);
        }
        animateCursorRing();

        // লিংক বা বাটনে হোভার করলে কার্সরের গ্লোয়িং এক্সপ্যান্ড ইফেক্ট
        document.querySelectorAll('a, button, [data-spotlight], .cursor-pointer').forEach(el => {
            el.addEventListener('mouseenter', () => {
                dot.style.transform = 'translate(-50%, -50%) scale(2)';
                dot.style.backgroundColor = '#fff';
                ring.style.width = '64px'; 
                ring.style.height = '64px';
                ring.style.borderColor = 'rgba(6, 182, 212, 1)';
                ring.style.backgroundColor = 'rgba(6, 182, 212, 0.1)';
            });
            el.addEventListener('mouseleave', () => {
                dot.style.transform = 'translate(-50%, -50%) scale(1)';
                dot.style.backgroundColor = '#06B6D4';
                ring.style.width = '46px'; 
                ring.style.height = '46px';
                ring.style.borderColor = 'rgba(6, 182, 212, 0.7)';
                ring.style.backgroundColor = 'rgba(6, 182, 212, 0.03)';
            });
        });

        // ৩D কন্টিনিউয়াস ভেক্টর ফ্লুইড রিবনস
        const canvas = document.getElementById('fluid');
        const ctx = canvas.getContext('2d');
        
        let width = canvas.width = window.innerWidth;
        let height = canvas.height = window.innerHeight;

        window.addEventListener('resize', () => {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
        });

        let targetMouseX = width / 2;
        let targetMouseY = height / 2;
        let currentMouseX = width / 2;
        let currentMouseY = height / 2;

        window.addEventListener('mousemove', (e) => {
            targetMouseX = e.clientX;
            targetMouseY = e.clientY;
        });

        function drawVectorFluidMesh(t) {
            ctx.clearRect(0, 0, width, height);

            currentMouseX += (targetMouseX - currentMouseX) * 0.05;
            currentMouseY += (targetMouseY - currentMouseY) * 0.05;

            let orbGradient1 = ctx.createRadialGradient(currentMouseX, currentMouseY, 10, width * 0.15, height * 0.8, 180);
            orbGradient1.addColorStop(0, 'rgba(6, 182, 212, 0.15)');
            orbGradient1.addColorStop(0.5, 'rgba(14, 165, 233, 0.05)');
            orbGradient1.addColorStop(1, 'rgba(0,0,0,0)');
            ctx.fillStyle = orbGradient1;
            ctx.beginPath(); ctx.arc(width * 0.15, height * 0.8, 250, 0, Math.PI * 2); ctx.fill();

            let totalRibbons = 12;
            for (let r = 0; r < totalRibbons; r++) {
                ctx.beginPath();
                let offsetCoeff = r / totalRibbons;
                let strokeWidth = 55 * (1 - offsetCoeff * 0.6);
                ctx.lineWidth = strokeWidth;
                
                let alpha = (0.28 * (1 - offsetCoeff)) + 0.03;
                ctx.strokeStyle = `rgba(6, 182, 212, ${alpha})`;

                for (let x = -50; x < width + 50; x += 15) {
                    let dx = x - currentMouseX;
                    let distortInertia = Math.exp(-Math.abs(dx) / 450);
                    let baseSine = Math.sin(x * 0.0022 + t * 0.0008 + offsetCoeff * 1.4);
                    let harmonicSine = Math.sin(x * 0.005 + t * 0.0015) * 0.25;
                    let y = height * 0.52 + (baseSine + harmonicSine) * (height * 0.22) + (currentMouseY - height * 0.5) * distortInertia * 0.75;

                    if (x === -50) ctx.moveTo(x, y);
                    else ctx.lineTo(x, y);
                }
                ctx.stroke();
            }
            requestAnimationFrame(drawVectorFluidMesh);
        }
        requestAnimationFrame((time) => drawVectorFluidMesh(time));

        // ন্যাভবার ইন্টারঅ্যাকশন
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if(window.scrollY > 40) {
                nav.style.background = 'rgba(3, 6, 17, 0.85)';
                nav.style.borderColor = 'rgba(6, 182, 212, 0.2)';
            } else {
                nav.style.background = 'rgba(3, 6, 17, 0.7)';
                nav.style.borderColor = 'rgba(255,255,255,0.04)';
            }
        });

        // স্পটলাইট ও ৩D টিল্ট ইফেক্ট কার্ড কন্ট্রোল
        document.querySelectorAll('[data-spotlight]').forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                card.style.background = `radial-gradient(600px circle at ${x}px ${y}px, rgba(6, 182, 212, 0.15), transparent 45%)`;
                
                const cardWidth = rect.width;
                const cardHeight = rect.height;
                const rotateX = ((y - (cardHeight / 2)) / (cardHeight / 2)) * -8;
                const rotateY = ((x - (cardWidth / 2)) / (cardWidth / 2)) * 8;
                
                card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.01)`;
            });

            card.addEventListener('mouseleave', () => {
                card.style.background = 'rgba(255, 255, 255, 0.02)';
                card.style.transform = 'rotateX(0deg) rotateY(0deg) scale(1)';
            });
        });

        // প্যারালাক্স ফ্লোটিং এলিমেন্টস
        window.addEventListener('mousemove', (e) => {
            const amountX = (e.clientX - window.innerWidth/2) * 0.03;
            const amountY = (e.clientY - window.innerHeight/2) * 0.03;
            document.querySelectorAll('.float-element').forEach(el => {
                const depth = el.getAttribute('data-depth');
                gsap.to(el, { x: amountX * depth, y: amountY * depth, duration: 0.4 });
            });
        });

        // হিরো সেকশন এন্ট্রি ও কাউন্টার সিকোয়েন্সার
        function triggerHeroAnimations() {
            gsap.from(".hero-text-block", { opacity: 0, y: 30, duration: 0.8, ease: "power3.out" });
            gsap.from(".dashboard-wrapper", { opacity: 0, scale: 0.97, duration: 1, ease: "power2.out" }, "-=0.5");
            
            document.querySelectorAll('.counter').forEach(c => {
                const target = +c.getAttribute('data-target');
                gsap.to(c, { innerText: target, duration: 1.8, snap: { innerText: 1 }, ease: "power2.out" });
            });
        }

        gsap.from(".feature-card", {
            scrollTrigger: { trigger: ".section-trigger", start: "top 75%" },
            opacity: 0, y: 40, duration: 0.6, stagger: 0.15, ease: "power2.out"
        });

        VanillaTilt.init(document.querySelectorAll(".showcase-card"), { max: 6, speed: 300 });
    </script>
</body>
</html>
